# ====================================================
# FreeAI Orchestrator — Environment Configuration
# ====================================================
# Kopieer dit bestand naar .env en vul je API keys in
# Alle keys zijn optioneel — het systeem gebruikt alleen
# providers waarvoor je een key hebt geconfigureerd.
# ====================================================

# === Server ===
NODE_ENV=production
PORT=5000
APP_URL=http://localhost:5000

# === Gratis AI Providers (chat/redeneren) ===

# Groq — https://console.groq.com/keys (gratis tier)
GROQ_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey (gratis tier)
GEMINI_API_KEY=

# OpenRouter — https://openrouter.ai/keys (gratis modellen beschikbaar)
OPENROUTER_API_KEY=

# HuggingFace — https://huggingface.co/settings/tokens (gratis inference)
HUGGINGFACE_API_KEY=

# SiliconFlow — https://cloud.siliconflow.cn (gratis tier)
SILICONFLOW_API_KEY=

# Cloudflare Workers AI — https://dash.cloudflare.com (gratis tier)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_KEY=

# GitHub Models — https://github.com/settings/tokens (gratis voor devs)
GITHUB_TOKEN=

# Ollama — lokale installatie (geen key nodig)
OLLAMA_URL=http://localhost:11434

# === CAPTCHA Solvers (optioneel) ===

# 2Captcha — https://2captcha.com
TWOCAPTCHA_API_KEY=

# CapSolver — https://www.capsolver.com
CAPSOLVER_API_KEY=

# === Browser Automation ===
# Playwright wordt automatisch geconfigureerd in Docker
# Voor lokaal: npx playwright install chromium
